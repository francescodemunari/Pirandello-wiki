# === Provider principale ===
ACTIVE_PROVIDER=lm_studio
# Options: lm_studio | ollama | llamacpp | openai | openrouter | anthropic | google

# === LM Studio (locale, OpenAI-compatibile) ===
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=Qwen3.5-9B-DeepSeek-V4-Flash-Q4_K_M

# === Ollama (locale) ===
OLLAMA_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# === llama.cpp (locale) ===
LLAMACPP_URL=http://localhost:8080/v1
LLAMACPP_MODEL=

# === OpenAI (cloud) ===
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# === OpenRouter (cloud — accesso unificato a molti modelli) ===
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=openai/gpt-4o

# === Anthropic Claude (cloud) ===
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# === Google Gemini (cloud) ===
GOOGLE_API_KEY=...
GOOGLE_MODEL=gemini-2.0-flash

# === Parametri per-provider (opzionali, default applicati) ===
# LM_STUDIO_TEMPERATURE=0.7
# LM_STUDIO_MAX_TOKENS=4096
# OLLAMA_TEMPERATURE=0.7
# OLLAMA_MAX_TOKENS=4096
# OPENAI_TEMPERATURE=0.7
# OPENAI_MAX_TOKENS=4096
# ANTHROPIC_TEMPERATURE=0.7
# ANTHROPIC_MAX_TOKENS=4096
# GOOGLE_TEMPERATURE=0.7
# GOOGLE_MAX_TOKENS=4096

# === Wiki ===
WIKI_PATH=./wiki

# === Server ===
PORT=8000

# === TTS (XTTS v2) ===
TTS_REFERENCE_WAV=./backend/voices/pirandello_ref.wav
TTS_LANG=it
TTS_USE_GPU=auto
TTS_PRELOAD=1
TTS_WORKER_TIMEOUT=900
TTS_PYTHON=py -3.11
